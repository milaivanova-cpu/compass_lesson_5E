<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Компас на ученето + 5E пътна карта</title>

  <style>
    :root {
      --bg: #f4f6f8;
      --card: #ffffff;
      --text: #172033;
      --muted: #667085;
      --line: #d0d5dd;
      --dark: #111827;
      --accent: #2563eb;
      --soft: #eef2ff;
      --green: #ecfdf3;
      --yellow: #fffaeb;
      --rose: #fff1f3;
      --shadow: 0 12px 30px rgba(16, 24, 40, 0.08);
      --radius: 24px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
    }

    .page {
      max-width: 1180px;
      margin: 0 auto;
      padding: 32px 20px 56px;
    }

    header {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 32px;
      box-shadow: var(--shadow);
      padding: 32px;
      margin-bottom: 28px;
    }

    .eyebrow {
      display: inline-block;
      background: #eef2f7;
      color: #344054;
      padding: 8px 14px;
      border-radius: 999px;
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 14px;
    }

    h1 {
      font-size: clamp(32px, 5vw, 54px);
      line-height: 1.05;
      margin: 0 0 14px;
      letter-spacing: -1px;
    }

    h2 {
      font-size: 30px;
      margin: 0 0 10px;
    }

    h3 {
      margin: 0 0 8px;
      font-size: 22px;
    }

    p {
      margin: 0;
    }

    .lead {
      max-width: 820px;
      font-size: 18px;
      color: var(--muted);
    }

    .rule {
      margin-top: 22px;
      padding: 16px 18px;
      border-radius: 18px;
      background: var(--dark);
      color: white;
      font-size: 16px;
    }

    .section {
      margin-top: 34px;
    }

    .section-title {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 18px;
    }

    .icon-box {
      width: 46px;
      height: 46px;
      border-radius: 16px;
      display: grid;
      place-items: center;
      background: var(--dark);
      color: white;
      font-size: 24px;
      flex: 0 0 auto;
    }

    .grid-two {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 24px;
      align-items: start;
    }

    .compass-card {
      position: relative;
      min-height: 460px;
      background: linear-gradient(135deg, #ffffff, #f8fafc);
      border: 1px solid var(--line);
      border-radius: 32px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .compass-center {
      position: absolute;
      left: 50%;
      top: 50%;
      width: 190px;
      height: 190px;
      transform: translate(-50%, -50%);
      border-radius: 50%;
      background: white;
      border: 2px solid #cbd5e1;
      box-shadow: 0 10px 25px rgba(16, 24, 40, 0.12);
      display: grid;
      place-items: center;
      text-align: center;
      padding: 22px;
      z-index: 2;
    }

    .compass-center .target {
      font-size: 30px;
      margin-bottom: 8px;
    }

    .compass-center strong {
      display: block;
      font-size: 16px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .compass-center span {
      display: block;
      color: var(--muted);
      font-size: 13px;
      margin-top: 6px;
    }

    .line-v-top,
    .line-v-bottom,
    .line-h-left,
    .line-h-right {
      position: absolute;
      background: var(--line);
      z-index: 1;
    }

    .line-v-top {
      width: 2px;
      height: 100px;
      left: 50%;
      top: 82px;
      transform: translateX(-50%);
    }

    .line-v-bottom {
      width: 2px;
      height: 100px;
      left: 50%;
      bottom: 82px;
      transform: translateX(-50%);
    }

    .line-h-left {
      height: 2px;
      width: 150px;
      top: 50%;
      left: 118px;
      transform: translateY(-50%);
    }

    .line-h-right {
      height: 2px;
      width: 150px;
      top: 50%;
      right: 118px;
      transform: translateY(-50%);
    }

    .point {
      position: absolute;
      width: 170px;
      border: 1px solid var(--line);
      border-radius: 20px;
      background: white;
      box-shadow: 0 6px 18px rgba(16, 24, 40, 0.08);
      padding: 14px;
      cursor: pointer;
      transition: 0.18s ease;
      z-index: 3;
      text-align: left;
      color: var(--text);
    }

    .point:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 24px rgba(16, 24, 40, 0.12);
    }

    .point.active {
      background: var(--dark);
      color: white;
      border-color: var(--dark);
    }

    .point .small {
      font-size: 12px;
      opacity: 0.7;
      margin-bottom: 2px;
    }

    .point .title {
      font-weight: 800;
      font-size: 17px;
    }

    .north {
      left: 50%;
      top: 22px;
      transform: translateX(-50%);
    }

    .south {
      left: 50%;
      bottom: 22px;
      transform: translateX(-50%);
    }

    .east {
      right: 22px;
      top: 50%;
      transform: translateY(-50%);
    }

    .west {
      left: 22px;
      top: 50%;
      transform: translateY(-50%);
    }

    .north:hover,
    .south:hover {
      transform: translateX(-50%) translateY(-2px);
    }

    .east:hover,
    .west:hover {
      transform: translateY(-50%) translateY(-2px);
    }

    .detail-card,
    .plain-card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 24px;
    }

    .detail-top {
      display: flex;
      gap: 14px;
      align-items: flex-start;
      margin-bottom: 16px;
    }

    .detail-icon {
      width: 48px;
      height: 48px;
      border-radius: 16px;
      background: #eef2f7;
      display: grid;
      place-items: center;
      font-size: 24px;
      flex: 0 0 auto;
    }

    .detail-label {
      font-size: 13px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 800;
    }

    .question {
      font-size: 18px;
      color: #344054;
      margin-top: 6px;
    }

    .description {
      color: var(--muted);
      margin-bottom: 16px;
    }

    .example-box {
      background: #f8fafc;
      border-radius: 18px;
      padding: 16px;
      margin-top: 14px;
    }

    .example-box strong {
      display: block;
      margin-bottom: 8px;
    }

    ul {
      margin: 0;
      padding-left: 22px;
    }

    li {
      margin: 7px 0;
    }

    .sentence {
      margin-top: 16px;
      padding: 14px;
      border: 1px dashed #98a2b3;
      border-radius: 16px;
      color: #344054;
      background: white;
    }

    .roadmap {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 12px;
      margin-bottom: 16px;
    }

    .phase {
      border: 1px solid var(--line);
      background: white;
      border-radius: 20px;
      padding: 16px;
      cursor: pointer;
      box-shadow: 0 6px 16px rgba(16, 24, 40, 0.06);
      transition: 0.18s ease;
      text-align: left;
    }

    .phase:hover {
      transform: translateY(-2px);
    }

    .phase.active {
      background: var(--dark);
      color: white;
      border-color: var(--dark);
    }

    .phase strong {
      display: block;
      font-size: 20px;
      margin-bottom: 4px;
    }

    .phase span {
      font-size: 13px;
      opacity: 0.78;
    }

    .phase-detail {
      background: white;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 24px;
    }

    .phase-detail .tag {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      font-weight: 800;
      margin-bottom: 6px;
    }

    .phase-detail .big-question {
      font-size: 19px;
      color: #344054;
      margin: 8px 0 12px;
    }

    .compass-link {
      margin-top: 14px;
      background: #f8fafc;
      padding: 14px;
      border-radius: 16px;
      color: #344054;
      font-size: 15px;
    }

    .example-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
      margin: 18px 0;
    }

    .mini-card {
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 16px;
      background: white;
    }

    .mini-card strong {
      display: block;
      margin-bottom: 6px;
    }

    .dark-box {
      background: var(--dark);
      color: white;
      border-radius: 20px;
      padding: 18px;
    }

    .template-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }

    .working-sentence {
      margin-top: 18px;
      border: 1px dashed #98a2b3;
      border-radius: 20px;
      background: white;
      padding: 20px;
      font-size: 17px;
    }

    .blank {
      font-weight: 800;
      color: var(--accent);
    }

    @media (max-width: 920px) {
      .grid-two {
        grid-template-columns: 1fr;
      }

      .roadmap,
      .example-grid,
      .template-grid {
        grid-template-columns: 1fr;
      }

      .compass-card {
        min-height: 560px;
      }

      .line-h-left,
      .line-h-right {
        display: none;
      }

      .point {
        width: 155px;
      }

      .east {
        right: 12px;
      }

      .west {
        left: 12px;
      }
    }

    @media (max-width: 620px) {
      header {
        padding: 24px;
      }

      .compass-card {
        min-height: 640px;
      }

      .compass-center {
        width: 160px;
        height: 160px;
      }

      .point {
        width: 150px;
      }

      .north {
        top: 16px;
      }

      .south {
        bottom: 16px;
      }

      .east {
        top: 62%;
        right: 12px;
      }

      .west {
        top: 62%;
        left: 12px;
      }

      .line-v-top,
      .line-v-bottom {
        display: none;
      }
    }
  </style>
</head>

<body>
  <main class="page">
    <header>
      <div class="eyebrow">🧭 Интерактивна карта за планиране</div>
      <h1>Компас на ученето + 5E пътна карта</h1>
      <p class="lead">
        Първо ориентираме ученето около една ясна урочна цел.
        После подреждаме дейностите в 5E модел на урока.
      </p>
      <div class="rule">
        <strong>Ключово правило:</strong>
        целта не е дейност. Дейностите са пътят, по който учениците стигат до разбиране.
      </div>
    </header>

    <section class="section grid-two">
      <div>
        <div class="section-title">
          <div class="icon-box">🧭</div>
          <div>
            <h2>Компас на ученето</h2>
            <p class="lead">Кликни върху посока, за да видиш какво решава учителят.</p>
          </div>
        </div>

        <div class="compass-card">
          <div class="line-v-top"></div>
          <div class="line-v-bottom"></div>
          <div class="line-h-left"></div>
          <div class="line-h-right"></div>

          <button class="point north active" data-point="north">
            <div class="small">Север</div>
            <div class="title">🧠 Мислене</div>
          </button>

          <button class="point east" data-point="east">
            <div class="small">Изток</div>
            <div class="title">📖 Език / четене</div>
          </button>

          <button class="point south" data-point="south">
            <div class="small">Юг</div>
            <div class="title">🧩 Когнитивна стратегия</div>
          </button>

          <button class="point west" data-point="west">
            <div class="small">Запад</div>
            <div class="title">🔁 Метакогнитивна пауза</div>
          </button>

          <div class="compass-center">
            <div>
              <div class="target">🎯</div>
              <strong>Урочна цел</strong>
              <span>Какво ще могат / разбират учениците?</span>
            </div>
          </div>
        </div>
      </div>

      <aside class="detail-card" id="detailCard"></aside>
    </section>

    <section class="section">
      <div class="section-title">
        <div class="icon-box">🗺️</div>
        <div>
          <h2>5E пътна карта на урока</h2>
          <p class="lead">Компасът ориентира ученето. 5E подрежда дейностите.</p>
        </div>
      </div>

      <div class="roadmap">
        <button class="phase active" data-phase="0">
          <strong>Engage</strong>
          <span>Въвеждане на смисъл</span>
        </button>
        <button class="phase" data-phase="1">
          <strong>Explore</strong>
          <span>Първа работа с материала</span>
        </button>
        <button class="phase" data-phase="2">
          <strong>Explain</strong>
          <span>Изясняване</span>
        </button>
        <button class="phase" data-phase="3">
          <strong>Elaborate</strong>
          <span>Задълбочаване</span>
        </button>
        <button class="phase" data-phase="4">
          <strong>Evaluate</strong>
          <span>Проверка на ученето</span>
        </button>
      </div>

      <div class="phase-detail" id="phaseDetail"></div>
    </section>

    <section class="section">
      <div class="section-title">
        <div class="icon-box">💡</div>
        <div>
          <h2>Пример: математика, V клас</h2>
          <p class="lead">Как очакван резултат от програмата се превежда в урок.</p>
        </div>
      </div>

      <div class="plain-card">
        <div class="example-box">
          <strong>От програмата</strong>
          <p>
            Очакван резултат: решава текстови задачи с практико-приложен характер,
            в които се използват знания за дробни числа.
          </p>
        </div>

        <div class="example-box" style="background: white; border: 1px solid var(--line);">
          <strong>Урочна цел</strong>
          <p>
            Учениците ще могат да решават текстова задача за част от число,
            като определят цялото, дробта и търсената част и записват подходящ числов израз.
          </p>
        </div>

        <div class="example-grid">
          <div class="mini-card">
            <strong>🧠 Мислене</strong>
            <p>Приложение — учениците използват знание за дроби в практическа задача.</p>
          </div>

          <div class="mini-card">
            <strong>📖 Език / четене</strong>
            <p>Разчитане на условие: кое е цялото, коя е дробта, какво се търси.</p>
          </div>

          <div class="mini-card">
            <strong>🧩 Когнитивна стратегия</strong>
            <p>Схема “цяло — дроб — търси се — израз”.</p>
          </div>

          <div class="mini-card">
            <strong>🔁 Метакогнитивна пауза</strong>
            <p>“Преди да смятам, очаквам ли резултатът да е по-малък или по-голям от цялото?”</p>
          </div>
        </div>

        <div class="dark-box">
          <strong>5E пътна карта</strong>
          <ul>
            <li><strong>Engage:</strong> житейска ситуация с част от цяло; учениците правят прогноза.</li>
            <li><strong>Explore:</strong> учениците решават две задачи, като попълват схемата.</li>
            <li><strong>Explain:</strong> класът извежда как разпознаваме “част от число” и как го записваме с израз.</li>
            <li><strong>Elaborate:</strong> нова задача в различен контекст — пари, време, разстояние.</li>
            <li><strong>Evaluate:</strong> exit ticket с нова задача и едно изречение защо резултатът има смисъл.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-title">
        <div class="icon-box">✅</div>
        <div>
          <h2>Шаблон за учителя</h2>
          <p class="lead">Една урочна цел, четири ориентира, после 5E.</p>
        </div>
      </div>

      <div class="template-grid">
        <div class="mini-card">
          <strong>1. Очакван резултат от програмата</strong>
          <p>Избирам резултат, но не го преписвам механично като урочна цел.</p>
        </div>

        <div class="mini-card">
          <strong>2. Урочна цел</strong>
          <p>В края на урока учениците ще могат да…</p>
        </div>

        <div class="mini-card">
          <strong>3. Компас</strong>
          <p>Мислене → Език/четене → Когнитивна стратегия → Метакогнитивна пауза.</p>
        </div>

        <div class="mini-card">
          <strong>4. 5E пътна карта</strong>
          <p>Engage → Explore → Explain → Elaborate → Evaluate.</p>
        </div>
      </div>

      <div class="working-sentence">
        <strong>Работно изречение:</strong><br />
        Учениците ще могат да
        <span class="blank">________</span>,
        като работят с
        <span class="blank">________</span>
        чрез стратегия
        <span class="blank">________</span>
        и проверят
        <span class="blank">________</span>.
      </div>
    </section>
  </main>

  <script>
    const compassData = {
      north: {
        label: "Север",
        icon: "🧠",
        title: "Мислене",
        question: "Какъв тип мислене изисква урочната цел?",
        description:
          "Тук учителят използва Блум като ориентир: дали учениците трябва да запомнят, разберат, приложат, анализират, оценят или създадат.",
        examples: [
          "Помнене: назовава понятия, факти, формули.",
          "Разбиране: обяснява със свои думи, дава пример.",
          "Приложение: използва правило, алгоритъм или модел.",
          "Анализ: открива части, връзки, причини, доказателства.",
          "Оценка: преценява по критерии и аргументира.",
          "Създаване: създава текст, модел, решение или продукт."
        ],
        prompt: "Учениците трябва да мислят на ниво: ________."
      },

      east: {
        label: "Изток",
        icon: "📖",
        title: "Език / четене",
        question: "През какъв език, текст или представяне ще мине ученето?",
        description:
          "Тук влиза четивната грамотност през предмета. Не всички преподават БЕЛ, но всички учители правят видим езика на своя предмет.",
        examples: [
          "Разбиране на инструкция или условие.",
          "Работа с непрекъснат текст.",
          "Работа с таблица, графика, диаграма или схема.",
          "Разбиране и използване на понятия и термини.",
          "Устно или писмено обяснение.",
          "Аргументация с доказателства.",
          "Превод от житейска ситуация към математически/научен модел."
        ],
        prompt:
          "За да постигнат целта, учениците трябва да прочетат/разберат/кажат/напишат: ________."
      },

      south: {
        label: "Юг",
        icon: "🧩",
        title: "Когнитивна стратегия",
        question: "Как учениците ще работят с материала?",
        description:
          "Стратегията е инструментът, чрез който учениците обработват информацията. Тя не е цел и не е дейност, а опора за мисленето.",
        examples: [
          "Повторение и извличане от паметта.",
          "Подчертаване по критерии.",
          "Записки, таблица, схема, модел.",
          "Обобщаване със свои думи.",
          "Свързване с предишно знание или личен опит.",
          "Пример / контрапример / аналогия.",
          "Твърдение – доказателство – обяснение.",
          "Обяснение на съученик или сравнение на решения."
        ],
        prompt: "Най-подходящата стратегия за тази цел е: ________."
      },

      west: {
        label: "Запад",
        icon: "🔁",
        title: "Метакогнитивна пауза",
        question: "Къде учениците ще проверят дали разбират и дали стратегията работи?",
        description:
          "Метакогнитивната пауза е кратък момент за планиране, мониторинг или оценка. Тя учи учениците да управляват собственото си учене.",
        examples: [
          "Преди задачата: Как ще подходя? Какво вече знам?",
          "По време на задачата: Разбирам ли? Работи ли стратегията ми?",
          "След задачата: Как разбрах, че съм научил? Какво ще променя?",
          "При трудност: Къде точно се затрудних? Каква друга стратегия мога да пробвам?"
        ],
        prompt: "Метакогнитивната пауза ще бъде: ________."
      }
    };

    const phaseData = [
      {
        phase: "Engage",
        title: "Въвеждане на смисъл",
        question: "Как ще създам нужда от ученето?",
        description:
          "Учениците активират предишно знание, любопитство, въпрос, проблем или житейска ситуация.",
        compassLink:
          "Най-често тук се появяват: език/четене + метакогнитивно планиране."
      },
      {
        phase: "Explore",
        title: "Изследване / първа работа с материала",
        question: "Как учениците първо ще работят с материала?",
        description:
          "Учениците пробват, четат, наблюдават, решават, събират информация или обсъждат преди пълното обяснение.",
        compassLink:
          "Най-често тук се появяват: езиков фокус + когнитивна стратегия."
      },
      {
        phase: "Explain",
        title: "Изясняване и назоваване",
        question: "Как ще стигнат до ясно понятие, правило, модел или обяснение?",
        description:
          "Учениците формулират разбиране, а учителят въвежда точния език, понятията и обобщението.",
        compassLink:
          "Най-често тук се появяват: мислене + език + обобщаване."
      },
      {
        phase: "Elaborate",
        title: "Задълбочаване и трансфер",
        question: "Как ще приложат наученото в нов контекст?",
        description:
          "Учениците използват новото знание в по-сложна, различна или практическа ситуация.",
        compassLink:
          "Най-често тук се появяват: по-високо мисловно ниво + стратегия за трансфер."
      },
      {
        phase: "Evaluate",
        title: "Проверка на ученето",
        question: "Как учениците ще покажат и проверят ученето си?",
        description:
          "Тук стои доказателството за учене: продукт, отговор, exit ticket, самооценка, анализ на грешка или кратка рефлексия.",
        compassLink:
          "Тук се връща метакогницията: Как разбрах, че съм научил?"
      }
    ];

    function renderCompassDetail(pointKey) {
      const data = compassData[pointKey];
      const detailCard = document.getElementById("detailCard");

      detailCard.innerHTML = `
        <div class="detail-top">
          <div class="detail-icon">${data.icon}</div>
          <div>
            <div class="detail-label">${data.label}</div>
            <h3>${data.title}</h3>
            <p class="question">${data.question}</p>
          </div>
        </div>

        <p class="description">${data.description}</p>

        <div class="example-box">
          <strong>Примерни ориентири</strong>
          <ul>
            ${data.examples.map(item => `<li>${item}</li>`).join("")}
          </ul>
        </div>

        <div class="sentence">
          <strong>Изречение за планиране:</strong>
          ${data.prompt}
        </div>
      `;
    }

    function renderPhaseDetail(index) {
      const data = phaseData[index];
      const phaseDetail = document.getElementById("phaseDetail");

      phaseDetail.innerHTML = `
        <div class="tag">${data.phase}</div>
        <h3>${data.title}</h3>
        <p class="big-question">${data.question}</p>
        <p class="description">${data.description}</p>
        <div class="compass-link">
          <strong>Връзка с компаса:</strong>
          ${data.compassLink}
        </div>
      `;
    }

    document.querySelectorAll(".point").forEach(button => {
      button.addEventListener("click", () => {
        document.querySelectorAll(".point").forEach(btn => btn.classList.remove("active"));
        button.classList.add("active");
        renderCompassDetail(button.dataset.point);
      });
    });

    document.querySelectorAll(".phase").forEach(button => {
      button.addEventListener("click", () => {
        document.querySelectorAll(".phase").forEach(btn => btn.classList.remove("active"));
        button.classList.add("active");
        renderPhaseDetail(Number(button.dataset.phase));
      });
    });

    renderCompassDetail("north");
    renderPhaseDetail(0);
  </script>
</body>
</html>
